subscription_id = "00000000-0000-0000-0000-000000000000"
tenant_id       = "00000000-0000-0000-0000-000000000000"
project_name    = "az-ir-platform"
environment     = "dev"
location        = "westeurope"
vnet_cidr       = ["10.40.0.0/16"]
subnet_cidrs = {
  management  = "10.40.1.0/24"
  application = "10.40.2.0/24"
  monitoring  = "10.40.3.0/24"
}
container_subnet_cidr = "10.40.4.0/24"
# Replace with trusted office/VPN egress CIDRs.
admin_source_cidrs = ["10.10.10.0/24"]
enable_app_vm_public_ip = true
vm_size            = "Standard_B1s"
admin_username     = "azureadmin"
# Use your real SSH public key from ~/.ssh/*.pub in local or secure pipeline variable injection.
admin_ssh_public_key = "ssh-rsa AAAAB3NzaC1yc2EAAAADAQABAAABAQCreplace-with-your-public-key"
enable_windows_vm        = false
windows_vm_size          = "Standard_B2s"
enable_management_vm_public_ip = false
windows_admin_username = "localadmin"
# Do not commit real passwords. Inject via secure secret variable in CI/CD or tfvars excluded from git.
windows_admin_password = "<set-from-secret-store>"
enable_monitoring          = true
enable_container_workload  = true
container_image            = "nginx:stable-alpine"
container_cpu              = 0.5
container_memory_gb        = 1
log_retention_in_days      = 7
cpu_alert_threshold_percent = 90
monitor_action_group_email_receivers = [
  {
    name          = "cloudsupport-oncall"
    email_address = "oncall@example.com"
  }
]
enable_backup                = false
backup_time_utc             = "23:00"
backup_daily_retention_count = 7
enable_rbac                           = true
pipeline_principal_object_id          = "<github-oidc-sp-object-id>"
admin_user_object_id                  = "<admin-user-or-group-object-id>"
monitoring_reader_principal_object_id = "<monitoring-reader-user-or-group-object-id>"
enable_governance_policy              = true
governance_required_tags              = ["environment", "owner", "cost_center", "business_unit"]
governance_allowed_vm_sizes           = ["Standard_B1s", "Standard_B2s", "Standard_D2s_v5"]
governance_enforce_public_ip_deny     = false
owner           = "cloud-support-team"
cost_center     = "CC-1000"
business_unit   = "it-operations"

extra_tags = {
  service              = "incident-response"
  workload_profile     = "dev-minimal-cost"
  security_posture     = "baseline"
}
